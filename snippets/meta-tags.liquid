{%- comment -%} Minimal social / SEO meta (ponytail: only what every page needs) {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
<meta property="og:title" content="{{ page_title | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
{%- if page_description -%}<meta property="og:description" content="{{ page_description | escape }}">{%- endif -%}
{%- assign og_image = page_image | default: settings.logo -%}
{%- if og_image -%}<meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="theme-color" content="{{ settings.color_bg }}">
