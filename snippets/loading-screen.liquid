{%- comment -%}
  Animated loading screen. Controlled by assets/loading.js, which fills the
  progress bar, wipes the overlay away once assets load, and hands off to the
  hero entrance. Hidden entirely if disabled in theme settings or when JS is off.
{%- endcomment -%}
{%- if settings.loading_enabled -%}
  <div class="loader" data-loader role="status" aria-live="polite">
    <div class="loader__inner text-center">
      <div class="loader__mark">
        {{- settings.loading_text | default: shop.name -}}
      </div>
      <div class="loader__bar"><span></span></div>
      <span class="visually-hidden">{{ 'general.loading' | t: default: 'Loading' }}…</span>
    </div>
  </div>
{%- endif -%}
