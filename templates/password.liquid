{% layout 'password' %}

<section class="section">
  <div class="container reveal" style="max-width: 34rem;">
    <p class="eyebrow">Melina</p>
    <h1 class="h-lg display" style="margin-top: 0.5rem;">{{ shop.name }}</h1>
    <p class="lede muted" style="margin-top: 1rem;">Opening soon.</p>

    <div style="margin-top: 2.75rem;">
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <p class="muted" style="margin-bottom: 1rem; color: var(--accent);">
            {{ 'general.password_page.login_form_error' | t }}
          </p>
        {%- endif -%}

        <div class="stack" style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
          <label class="label" for="Password" style="position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0);">
            {{ 'general.password_page.password_label' | t }}
          </label>
          <input
            type="password"
            name="password"
            id="Password"
            autocomplete="off"
            placeholder="Password"
            style="max-width: 16rem;">
          <button type="submit" class="btn" data-magnetic="0.2">Enter</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
