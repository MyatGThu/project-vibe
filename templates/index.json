      "blocks": {
        "p1": { "type": "product", "settings": { "title": "The Monolith Coat", "category": "Outerwear", "price": "$1,290.00", "price_cents": 129000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091422_c2badeb9-c882-4b3f-a31b-2cf93706987c.png", "description": "<p>Dry charcoal wool, double-breasted, cut to stand on its own. It holds you at the waist and falls straight. Made to order in 3–4 weeks.</p>" } },
        "p2": { "type": "product", "settings": { "title": "The Liquid Slip", "category": "Dresses", "price": "$690.00", "price_cents": 69000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091425_7152fa25-d250-4715-b1f8-8eed1236736e.png", "description": "<p>Oyster satin, cut on the bias, poured over a soft cowl. It moves when you do and weighs almost nothing.</p>" } },
        "p3": { "type": "product", "settings": { "title": "The Null Suit", "category": "Tailoring", "price": "$1,450.00", "price_cents": 145000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091428_5ff778aa-f014-4b3d-8b41-2935c5cb917e.png", "description": "<p>A single-button blazer and straight trouser in ink wool, worn over a silk shell. Sharp, and quiet with it.</p>" } },
        "p4": { "type": "product", "settings": { "title": "The Vapor Knit", "category": "Knitwear", "price": "$520.00", "price_cents": 52000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091429_b3f6b442-56a0-4db4-8fc7-0308d53facfe.png", "description": "<p>A sheer fine-gauge column dress in smoke grey over a soft slip lining. Barely there, and made to layer.</p>" } },
        "p5": { "type": "product", "settings": { "title": "The Obsidian Trouser", "category": "Tailoring", "price": "$580.00", "price_cents": 58000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091438_0f50da26-d92a-45d1-aabc-ded6a06a4a7a.png", "description": "<p>A high-waisted wide-leg trouser in ink wool, with a champagne silk shell and a slim leather belt. It moves like a skirt.</p>" } },
        "p6": { "type": "product", "settings": { "title": "The Halo Gown", "category": "Eveningwear", "price": "$2,400.00", "price_cents": 240000, "sizes": "XS, S, M, L", "image_url": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_091440_6e97a702-fda1-4421-b926-03f6ab10b513.png", "description": "<p>A one-shoulder gown in bone crepe, with a train that trails behind you. Made to your measure.</p>" } }
