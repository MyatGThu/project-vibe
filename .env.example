# Copy to .env and fill in. NEVER commit the real .env.
# These are only needed for advanced/headless or Storefront API experiments —
# a standard custom theme authenticates via the Shopify CLI login, not tokens.

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Storefront API token (only if you later add custom API-driven features)
SHOPIFY_STOREFRONT_API_TOKEN=
