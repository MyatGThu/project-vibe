<section class="section">
  <div class="container">
    <h1 data-reveal style="margin-bottom: var(--space-xl);">{{ page_title | default: "Collections" }}</h1>
    <div class="product-grid" data-reveal-group>
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="product-card" data-reveal>
          <div class="product-card__media">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw', widths: '300, 450, 600, 800', alt: collection.title }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="product-card__title">{{ collection.title }}</div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collections list" }
{% endschema %}
