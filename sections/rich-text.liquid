<section class="section{% if section.settings.dark %} section--ink{% endif %}">
  <div class="container container--narrow text-center stack">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow" data-reveal="fade">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 data-reveal>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="lead flow" data-reveal>{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <div data-reveal="fade">
        <a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed to stand out" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every piece is made to order and styled by Melina, our digital muse.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "dark", "label": "Dark background", "default": false }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
