{%- liquid
  assign heading = section.settings.heading
  assign words = heading | split: ' '
-%}
<section class="hero" data-hero>
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1600 | image_tag: widths: '800,1200,1800,2400', sizes: '100vw', fetchpriority: 'high', alt: heading }}
    {%- elsif section.settings.image_url != blank -%}
      <img src="{{ section.settings.image_url }}" alt="{{ heading | escape }}" fetchpriority="high">
    {%- else -%}
      <img src="{{ 'ph-wide.svg' | asset_url }}" alt="{{ heading | escape }}">
    {%- endif -%}
  </div>

  <div class="hero__inner container container--wide">
    {%- if section.settings.eyebrow != blank -%}<p class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    <h1 class="hero__title display">{% for w in words %}<span class="word"><span>{{ w }}</span></span> {% endfor %}</h1>
    <div class="hero__meta">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="btn" data-magnetic="0.3">{{ section.settings.cta_text }}</a>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}<span style="max-width:34ch;color:rgba(255,255,255,0.85)">{{ section.settings.subtext }}</span>{%- endif -%}
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">Scroll</div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Autumn — made to be loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Couture, rendered." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "A women's-wear house. Melina wears every look first." },
    { "type": "text", "id": "cta_text", "label": "Button", "default": "Step inside" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_url", "label": "Hero image URL (fallback)", "info": "Used until you upload a hero image.", "default": "https://d8j0ntlcm91z4.cloudfront.net/user_31workO8jZ5gU3syoAaChkbmNoX/hf_20260712_101609_eafe04a9-e9bf-4b93-96a5-6612507a3113.png" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
