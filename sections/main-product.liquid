<style>
  .pdp { display: grid; gap: var(--space-2xl); grid-template-columns: 1.1fr 0.9fr; align-items: start; }
  .pdp__info { position: sticky; top: 96px; }
  .pdp__media img { width: 100%; border-radius: var(--radius-sm); margin-bottom: var(--space-sm); }
  .pdp select, .pdp input[type="number"] {
    padding: 0.7em 0.9em; border: 1px solid var(--color-line);
    border-radius: var(--radius-sm); background: var(--color-surface); width: 100%;
  }
  @media (max-width: 750px) {
    .pdp { grid-template-columns: 1fr; }
    .pdp__info { position: static; }
  }
</style>

<section class="section">
  <div class="container">
    <div class="pdp">
      <div class="pdp__media stack-sm" data-reveal>
        {%- for media in product.media limit: 5 -%}
          {{ media | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 55vw, 100vw', widths: '450, 700, 900, 1200', alt: product.title }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endfor -%}
      </div>

      <div class="pdp__info stack" data-reveal="right">
        <div class="stack-sm">
          {%- if product.vendor != blank -%}<p class="eyebrow">{{ product.vendor }}</p>{%- endif -%}
          <h1>{{ product.title }}</h1>
          <p class="lead" style="color: var(--color-ink);">{{ product.selected_or_first_available_variant.price | money }}</p>
        </div>

        {%- form 'product', product -%}
          {%- unless product.has_only_default_variant -%}
            <div class="stack-sm">
              <label class="eyebrow" for="variant">Options</label>
              <select id="variant" name="id">
                {%- for variant in product.variants -%}
                  <option value="{{ variant.id }}"{% if variant == product.selected_or_first_available_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                    {{ variant.title }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}

          <div class="stack-sm">
            <label class="eyebrow" for="qty">{{ 'products.product.quantity' | t }}</label>
            <input type="number" id="qty" name="quantity" value="1" min="1">
          </div>

          <button type="submit" name="add" class="btn"{% unless product.available %} disabled{% endunless %}>
            {%- if product.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
          </button>
        {%- endform -%}

        {%- comment -%} Note: option <select> swaps the whole variant natively (no JS).
          A future enhancement can add live price/media updates on change. {%- endcomment -%}

        {%- if product.description != blank -%}
          <div class="flow" style="margin-top: var(--space-md);">{{ product.description }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Product information" }
{% endschema %}
