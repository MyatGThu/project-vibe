<section class="section">
  <div class="container" style="max-width: 460px;">
    <header class="reveal" style="margin-bottom: 2rem;">
      <p class="eyebrow">Account</p>
      <h1 class="h-md">Reset password</h1>
      <p class="muted">Enter a new password for your account.</p>
    </header>

    {% form 'reset_customer_password' %}
      {{ form.errors | default_errors }}

      <div class="option">
        <label class="label" for="reset_password">New password</label>
        <input type="password" name="customer[password]" id="reset_password" autocomplete="new-password" autofocus>
      </div>

      <div class="option">
        <label class="label" for="reset_password_confirmation">Confirm password</label>
        <input type="password" name="customer[password_confirmation]" id="reset_password_confirmation" autocomplete="new-password">
      </div>

      <button type="submit" class="btn btn--block btn--lg" data-magnetic="0.2">Reset password</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
