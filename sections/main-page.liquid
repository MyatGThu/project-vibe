<section class="section">
  <div class="container container--narrow stack">
    <h1 data-reveal>{{ page.title }}</h1>
    {%- if page.content != blank -%}
      <div class="flow" data-reveal>{{ page.content }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Page" }
{% endschema %}
