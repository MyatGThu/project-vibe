<footer class="site-footer">
  <div class="container footer-grid">
    <div class="stack-sm">
      <p class="site-header__brand" style="color: var(--color-on-ink);">
        {{- section.settings.brand_text | default: shop.name -}}
      </p>
      {%- if section.settings.tagline != blank -%}
        <p class="muted">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      <div class="stack-sm" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <p class="eyebrow">{{ block.settings.heading }}</p>
        {%- endif -%}
        {%- if block.settings.menu != blank -%}
          <ul role="list" class="stack-sm">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="container" style="margin-top: var(--space-2xl);">
    <p class="muted" style="font-size: var(--fs-300);">
      © {{ "now" | date: "%Y" }} {{ shop.name }}.
      {{ section.settings.copyright }}
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand text" },
    { "type": "text", "id": "tagline", "label": "Tagline" },
    { "type": "text", "id": "copyright", "label": "Copyright note" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
