{%- comment -%}
  Te Amo — scroll landing.
  Progressive enhancement: the first slide + headline are a plain hero without JS.
  With GSAP + ScrollTrigger (already vendored) motion.js adds `is-live`, pins the
  viewport, runs a fast scroll-driven slideshow of the looks, then an outward zoom
  + blur into the next section — no new dependency.
{%- endcomment -%}
{%- liquid
  assign heading = section.settings.heading
  assign words = heading | split: ' '
-%}
<section class="l3d" data-l3d>
  <div class="l3d__viewport" data-l3d-viewport>
    <div class="l3d__slides" data-l3d-slides>
      {%- comment -%} Slide 0 — background hero {%- endcomment -%}
      <div class="l3d__slide" data-cap="{{ section.settings.eyebrow | escape }}">
        {%- if section.settings.bg_image != blank -%}
          {{ section.settings.bg_image | image_tag: widths: '800,1200,1800,2400', sizes: '100vw', fetchpriority: 'high', alt: '' }}
        {%- elsif section.settings.bg_image_url != blank -%}
          <img src="{{ section.settings.bg_image_url }}" alt="" fetchpriority="high">
        {%- else -%}
          <img src="{{ 'ph-wide.svg' | asset_url }}" alt="">
        {%- endif -%}
      </div>
      {%- comment -%} Look slides — eager so the fast slideshow never flips to a blank frame {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="l3d__slide" data-cap="{{ block.settings.caption | escape }}" data-tag="{{ block.settings.tag | escape }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_tag: widths: '800,1200,1800', sizes: '100vw', loading: 'eager', alt: block.settings.caption }}
          {%- elsif block.settings.image_url != blank -%}
            <img src="{{ block.settings.image_url }}" alt="{{ block.settings.caption | escape }}" loading="eager">
          {%- else -%}
            <img src="{{ 'ph-figure.svg' | asset_url }}" alt="" loading="eager">
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    <div class="l3d__scrim"></div>

    <div class="l3d__hud" data-l3d-hud>
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow l3d__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h1 class="l3d__title display reveal-words">{% for w in words %}<span class="reveal-word">{{ w }}</span> {% endfor %}</h1>
      {%- if section.settings.subtext != blank -%}<p class="l3d__sub">{{ section.settings.subtext }}</p>{%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="btn" data-magnetic="0.3">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>

    <div class="l3d__slidecap" data-l3d-cap aria-hidden="true"></div>
    <div class="l3d__cue" data-l3d-cue aria-hidden="true">{{ section.settings.scroll_label | default: 'Scroll to enter' }}</div>
  </div>
</section>

{% schema %}
{
  "name": "3D landing",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Autumn — Collection 01" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Couture, rendered." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "A fashion house dressed on an AI muse — scroll to step inside the atelier." },
    { "type": "text", "id": "cta_text", "label": "Button", "default": "Enter the collection" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "scroll_label", "label": "Scroll cue", "default": "Scroll to enter" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "text", "id": "bg_image_url", "label": "Background image URL (fallback)", "info": "Used until you upload a background image." }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL (fallback)" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "tag", "label": "Tag" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "3D landing", "blocks": [ { "type": "look" }, { "type": "look" }, { "type": "look" }, { "type": "look" } ] }
  ]
}
{% endschema %}
