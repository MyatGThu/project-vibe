{%- liquid
  assign coll = collections[section.settings.collection]
  assign has_products = false
  if coll != blank and coll.products_count > 0
    assign has_products = true
  endif
-%}
<section class="section" data-section-type="featured-collection">
  <div class="container">
    <div class="collection-head reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2 class="h-md" style="margin-top:.5rem">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link != blank -%}<a class="link-underline" href="{{ section.settings.link }}">{{ section.settings.link_text | default: 'View all' }} →</a>{%- endif -%}
    </div>

    <div class="product-grid">
      {%- if has_products -%}
        {%- for product in coll.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product, reveal_index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} No store collection yet → render the demo blocks as cards. {%- endcomment -%}
        {% render 'demo-product-card' for section.blocks as block %}
      {%- endif -%}
    </div>
  </div>

  {%- unless has_products -%}
    {%- comment -%} Demo mode: make quick-view work with no store products yet {%- endcomment -%}
    {% render 'demo-preview-data', blocks: section.blocks %}
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Made to order" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Autumn, held close" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave empty to show the demo capsule below." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products", "default": 8 },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "View all" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    { "type": "product", "name": "Demo product", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "The Monolith Coat" },
      { "type": "text", "id": "category", "label": "Category", "default": "Outerwear" },
      { "type": "text", "id": "price", "label": "Price (display)", "default": "$1,290.00" },
      { "type": "number", "id": "price_cents", "label": "Price (cents, for cart)", "default": 129000 },
      { "type": "text", "id": "sizes", "label": "Sizes (comma)", "default": "XS, S, M, L" },
      { "type": "text", "id": "image_url", "label": "Image URL" },
      { "type": "text", "id": "hover_image_url", "label": "Hover image URL (close-up / detail)", "info": "Revealed on hover — a tighter, different-angle shot of the same piece (jewelry-style). Falls back to the main image if left blank." },
      { "type": "richtext", "id": "description", "label": "Description" }
    ] }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
