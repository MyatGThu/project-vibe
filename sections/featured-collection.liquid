{%- comment -%}
  Scroll-revealed product grid. Cards fade/rise in a stagger via
  [data-reveal-group] + [data-reveal] (theme.js). Shows styled placeholders
  until a collection with products is selected.
{%- endcomment -%}
<section class="section featured-collection">
  <div class="container">
    <header class="stack-sm" style="margin-bottom: var(--space-xl);">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow" data-reveal="fade">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 data-reveal>{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>

    {%- assign collection = collections[section.settings.collection] -%}
    <div class="product-grid" data-reveal-group>
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <a href="{{ product.url }}" class="product-card" data-reveal>
            <div class="product-card__media">
              {%- if product.featured_media -%}
                {{
                  product.featured_media
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 25vw, 50vw',
                    widths: '300, 450, 600, 800',
                    alt: product.title
                }}
              {%- endif -%}
            </div>
            <div class="product-card__title">{{ product.title }}</div>
            <div class="product-card__price">
              {%- if product.compare_at_price > product.price -%}<span class="muted"><s>{{ product.compare_at_price | money }}</s></span> {% endif -%}
              {{ product.price | money }}
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          {%- assign ph = forloop.index0 | modulo: 6 | plus: 1 -%}
          <div class="product-card" data-reveal>
            <div class="product-card__media">
              {{ 'product-' | append: ph | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__title">Product title</div>
            <div class="product-card__price">$00.00</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="text-center" style="margin-top: var(--space-2xl);" data-reveal="fade">
        <a href="{{ collection.url }}" class="btn btn--ghost">{{ 'collections.general.view_all' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New in" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The latest drop" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'view all' button", "default": true }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
