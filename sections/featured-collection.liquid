{%- liquid
  assign coll = collections[section.settings.collection]
  assign has_products = false
  if coll != blank and coll.products_count > 0
    assign has_products = true
  endif
-%}
<section class="section" data-section-type="featured-collection">
  <div class="container">
    <div class="collection-head reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2 class="h-md" style="margin-top:.5rem">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link != blank -%}<a class="link-underline" href="{{ section.settings.link }}">{{ section.settings.link_text | default: 'View all' }} →</a>{%- endif -%}
    </div>

    <div class="product-grid">
      {%- if has_products -%}
        {%- for product in coll.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product, reveal_index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign handle = block.settings.title | handle
            if block.settings.image_url != blank
              assign card_img = block.settings.image_url
            else
              assign card_img = 'ph-figure.svg' | asset_url
            endif
          -%}
          <article class="card card--hide-face reveal" data-product data-handle="{{ handle }}" data-product-url="#"
            data-title="{{ block.settings.title | escape }}" data-reveal-delay="{{ forloop.index0 | times: 0.05 }}" {{ block.shopify_attributes }}>
            <div class="card__media" data-quick-view-trigger tabindex="0" role="button" aria-haspopup="dialog" aria-label="{{ 'products.product.quick_view' | t }}: {{ block.settings.title | escape }}">
              <img class="card__img card__img--front" src="{{ card_img }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              <img class="card__img card__img--model" src="{{ card_img }}" alt="{{ block.settings.title | escape }} worn by Melina" loading="lazy">
              {%- if settings.made_to_order -%}<div class="card__badges"><span class="badge badge--mto">Made to order</span></div>{%- endif -%}
              <div class="card__tools"><button type="button" class="icon-btn" data-quick-add aria-label="{{ 'products.product.choose_options' | t }}">+</button></div>
            </div>
            <div class="card__body">
              <div><h3 class="card__title">{{ block.settings.title }}</h3><p class="card__cat">{{ block.settings.category }}</p></div>
              <p class="card__price">{{ block.settings.price }}</p>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  {%- unless has_products -%}
    {%- comment -%} Demo mode: make quick-view work with no store products yet {%- endcomment -%}
    <script>
      window.__PREVIEW_PRODUCTS__ = Object.assign(window.__PREVIEW_PRODUCTS__ || {}, {
        {%- for block in section.blocks -%}
          {%- assign handle = block.settings.title | handle -%}
          {%- assign sizes = block.settings.sizes | split: ',' -%}
          {{ handle | json }}: {
            "title": {{ block.settings.title | json }},
            "type": {{ block.settings.category | json }},
            "price": {{ block.settings.price_cents | default: 0 }},
            "url": "#",
            "description": {{ block.settings.description | json }},
            "images": [{{ block.settings.image_url | json }}],
            "options": [{ "name": "Size", "position": 1, "values": [{% for s in sizes %}{{ s | strip | json }}{% unless forloop.last %},{% endunless %}{% endfor %}] }],
            "variants": [{% for s in sizes %}{ "id": {{ block.id | append: '-' | append: forloop.index | json }}, "title": {{ s | strip | json }}, "option1": {{ s | strip | json }}, "price": {{ block.settings.price_cents | default: 0 }}, "available": true }{% unless forloop.last %},{% endunless %}{% endfor %}]
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      });
    </script>
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Made to order" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Autumn, held close" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave empty to show the demo capsule below." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products", "default": 8 },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "View all" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    { "type": "product", "name": "Demo product", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "The Monolith Coat" },
      { "type": "text", "id": "category", "label": "Category", "default": "Outerwear" },
      { "type": "text", "id": "price", "label": "Price (display)", "default": "$1,290.00" },
      { "type": "number", "id": "price_cents", "label": "Price (cents, for cart)", "default": 129000 },
      { "type": "text", "id": "sizes", "label": "Sizes (comma)", "default": "XS, S, M, L" },
      { "type": "text", "id": "image_url", "label": "Image URL" },
      { "type": "richtext", "id": "description", "label": "Description" }
    ] }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
