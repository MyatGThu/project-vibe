<div class="announcement" role="region" aria-label="Announcement">
  <div class="container">
    <span>{{ section.settings.text }}</span>
    {%- if section.settings.link_text != blank -%}
      <a class="link-underline" href="{{ section.settings.link }}">{{ section.settings.link_text }}</a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Complimentary shipping on all made-to-order pieces — worldwide." },
    { "type": "text", "id": "link_text", "label": "Link text" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
