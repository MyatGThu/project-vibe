<header class="site-header">
  <div class="container site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__brand">
      {{- section.settings.brand_text | default: shop.name -}}
    </a>

    <nav class="site-nav" aria-label="Primary">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <a href="{{ routes.search_url }}" aria-label="{{ 'general.search.placeholder' | t }}">{{ 'general.search.placeholder' | t }}</a>
      <a href="{{ routes.cart_url }}" class="header-cart">
        {{- 'sections.header.cart' | t }} <span data-cart-count>({{ cart.item_count }})</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "info": "Leave blank to use the store name"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
