<header class="header" data-header>
  <div class="header__left">
    <button class="header__icon" data-nav-toggle aria-label="{{ 'accessibility.menu' | t }}" aria-controls="NavDrawer" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
    </button>
    {%- if linklists[section.settings.menu].links.size > 0 -%}
      <nav class="header__nav" aria-label="{{ 'accessibility.menu' | t }}">
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}"{% if link.active or link.child_active %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>

  <div class="header__brand">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 480 | image_tag: class: 'header__logo', style: 'width:' | append: settings.logo_width | append: 'px', alt: shop.name }}
      {%- else -%}
        <span class="wordmark">{{ settings.brand_name | default: shop.name }}</span>
      {%- endif -%}
    </a>
  </div>

  <div class="header__actions">
    <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'general.search.search' | t }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20.5 20.5 17 17" stroke-linecap="round"/></svg>
    </a>
    <button class="header__icon" data-cart-toggle aria-label="{{ 'accessibility.cart' | t }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6.5a3 3 0 0 1 6 0V8" stroke-linecap="round"/></svg>
      <span class="cart-count" data-count="{{ cart.item_count }}">{{ cart.item_count }}</span>
    </button>
  </div>
</header>

{%- comment -%} Menu drawer, opened by the burger. Slides in from the left. {%- endcomment -%}
<div class="drawer__overlay" data-nav-overlay></div>
<nav class="drawer drawer--left" id="NavDrawer" aria-label="{{ 'accessibility.menu' | t }}" hidden>
  <div class="drawer__head">
    <span class="eyebrow">{{ 'accessibility.menu' | t }}</span>
    <button class="header__icon" data-nav-toggle aria-label="{{ 'accessibility.close' | t }}" style="font-size:1.5rem">&times;</button>
  </div>
  <div class="drawer__items">
    {%- for link in linklists[section.settings.menu].links -%}
      <a href="{{ link.url }}" class="h-sm" style="font-family:var(--display-font)">{{ link.title }}</a>
    {%- endfor -%}
    <a href="{{ routes.search_url }}" class="h-sm" style="font-family:var(--display-font)">{{ 'general.search.search' | t }}</a>
  </div>
</nav>

{%- comment -%} Cart drawer, controlled by store.js {%- endcomment -%}
<div class="drawer__overlay" data-drawer-overlay></div>
<aside class="drawer" id="CartDrawer" aria-label="{{ 'cart.general.title' | t }}">
  <div class="drawer__head">
    <span class="eyebrow">{{ 'cart.general.title' | t }}</span>
    <button class="header__icon" data-cart-close aria-label="{{ 'accessibility.close' | t }}" style="font-size:1.5rem">&times;</button>
  </div>
  <div class="drawer__items" data-cart-items>
    <p class="muted">{{ 'cart.general.empty' | t }}</p>
  </div>
  <div class="drawer__foot">
    <div class="drawer__subtotal"><span>{{ 'cart.general.subtotal' | t }}</span><span data-cart-subtotal>{{ cart.total_price | money }}</span></div>
    <p class="muted" style="font-size:var(--step--1)">{{ 'cart.general.taxes_note' | t }}</p>
    <form action="{{ routes.cart_url }}" method="post">
      <button type="submit" name="checkout" class="btn btn--block btn--lg" data-magnetic="0.2">{{ 'cart.general.checkout' | t }}</button>
    </form>
  </div>
</aside>

<script>
  // Menu drawer open/close (burger, overlay, links, Esc)
  (function () {
    var d = document.getElementById('NavDrawer');
    var ov = document.querySelector('[data-nav-overlay]');
    if (!d) return;
    function setOpen(open) {
      if (open) d.removeAttribute('hidden');
      requestAnimationFrame(function () {
        d.classList.toggle('is-open', open);
        if (ov) ov.classList.toggle('is-open', open);
        document.documentElement.style.overflow = open ? 'hidden' : '';
        document.dispatchEvent(new CustomEvent('theme:scroll-lock', { detail: open }));
        var t = document.querySelector('.header [data-nav-toggle]'); if (t) t.setAttribute('aria-expanded', open);
      });
      if (!open) setTimeout(function () { d.setAttribute('hidden', ''); }, 500);
    }
    document.addEventListener('click', function (e) {
      if (e.target.closest('[data-nav-toggle]')) { e.preventDefault(); setOpen(d.hasAttribute('hidden')); }
      else if (e.target.closest('[data-nav-overlay]')) { setOpen(false); }
      else if (e.target.closest('#NavDrawer a')) { setOpen(false); }
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !d.hasAttribute('hidden')) setOpen(false); });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
