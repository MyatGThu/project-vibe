{%- comment -%}
  Melina — Category showcase (Gym / Swimwear / Dress).
  A full-bleed, self-themed panel that opens one of the three worlds and links to its
  landing page. NO prices — this is an invitation, not a product grid.

  3D parallax: the look "plates" sit inside a perspective stage and drift at their own
  depth-scaled rates as the panel crosses the viewport (motion.js, [data-cshow]); the
  stage tilts on rotateX for a subtle camera move. Desktop enhancement only —
  static-first, so without JS / with reduced-motion / on a handset it's a clean,
  readable themed composition.

  The palette is scoped to the panel via `.cshow--{theme}` (mirroring the collection
  palettes in base.css), so all three can live on one page, each in its own colours.
{%- endcomment -%}
{%- comment -%} Parallax depth per plate is derived from its position (front plate drifts most),
  so the schema needs no decimal `range` setting — Shopify's GitHub sync rejects those. {%- endcomment -%}
{%- liquid
  assign theme = section.settings.theme | default: 'dress'
  assign words = section.settings.heading | split: ' '
  assign plate_depths = '0.5,0.32,0.2,0.14' | split: ','
-%}
<section class="cshow cshow--{{ theme }}" data-cshow>
  <div class="cshow__frame">
    <div class="cshow__glow" aria-hidden="true" data-cshow-par="-0.1"></div>

    <div class="cshow__gallery" data-cshow-stage>
      {%- assign pi = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'plate' -%}
          {%- liquid
            assign pi = pi | plus: 1
            if block.settings.image != blank
              assign src = block.settings.image | image_url: width: 900
            elsif block.settings.image_url != blank
              assign src = block.settings.image_url
            else
              assign src = 'ph-figure.svg' | asset_url
            endif
            assign didx = pi | minus: 1
            assign depth = plate_depths[didx] | default: 0.24
          -%}
          <figure class="cshow__plate cshow__plate--{{ pi }}" data-cshow-par="{{ depth }}" {{ block.shopify_attributes }}>
            <img src="{{ src }}" alt="{{ block.settings.alt | default: block.settings.caption | escape }}" loading="lazy" decoding="async" width="900" height="1200">
            {%- if block.settings.caption != blank -%}<figcaption>{{ block.settings.caption }}</figcaption>{%- endif -%}
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cshow__body">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow cshow__eyebrow reveal">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2 class="cshow__title display reveal-words">{% for w in words %}<span class="reveal-word">{{ w }}</span> {% endfor %}</h2>
      {%- if section.settings.subtext != blank -%}<p class="cshow__sub reveal">{{ section.settings.subtext }}</p>{%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a class="btn cshow__cta reveal" href="{{ section.settings.cta_link | default: '#' }}" data-magnetic="0.3">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category showcase",
  "tag": "section",
  "settings": [
    { "type": "select", "id": "theme", "label": "World / palette", "options": [
      { "value": "gym", "label": "Gym (red + black)" },
      { "value": "swim", "label": "Swimwear (blue + yellow)" },
      { "value": "dress", "label": "Dress (ink + gold)" }
    ], "default": "dress" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A world of its own." },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "cta_text", "label": "Button", "default": "Enter" },
    { "type": "url", "id": "cta_link", "label": "Button link (the landing page)" }
  ],
  "blocks": [
    {
      "type": "plate",
      "name": "Look plate",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL (fallback)", "info": "Used until you upload an image." },
        { "type": "text", "id": "alt", "label": "Alt text (accessibility)", "info": "Describes the image for screen readers and SEO. Falls back to the caption if left blank." },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    { "name": "Category showcase", "blocks": [ { "type": "plate" }, { "type": "plate" }, { "type": "plate" } ] }
  ]
}
{% endschema %}
