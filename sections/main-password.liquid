<div class="stack" style="margin-top: var(--space-xl);">
  {%- if section.settings.message != blank -%}
    <p class="lead" data-reveal style="color: rgba(246, 243, 238, 0.85);">{{ section.settings.message }}</p>
  {%- endif -%}

  {%- form 'storefront_password' -%}
    {%- if form.errors -%}
      <p class="muted">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div style="display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap;" data-reveal="fade">
      <input type="password" name="password" placeholder="Password" style="padding: 0.8em; border: 1px solid rgba(246, 243, 238, 0.3); background: transparent; color: var(--color-on-ink);">
      <button type="submit" class="btn btn--ghost" style="color: var(--color-on-ink);">Enter</button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Password content",
  "settings": [
    { "type": "text", "id": "message", "label": "Message", "default": "Something special is coming." }
  ]
}
{% endschema %}
