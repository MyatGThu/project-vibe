<section class="section">
  <div class="container">
    <form action="{{ routes.search_url }}" method="get" role="search" class="stack-sm" style="max-width: 520px; margin-bottom: var(--space-xl);" data-reveal>
      <label class="eyebrow" for="q">{{ 'general.search.placeholder' | t }}</label>
      <input type="search" id="q" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" style="padding: 0.8em; border: 1px solid var(--color-line); width: 100%;">
    </form>

    {%- if search.performed -%}
      <h2 data-reveal style="margin-bottom: var(--space-lg);">{{ 'general.search.results' | t: terms: search.terms }}</h2>
      <div class="product-grid" data-reveal-group>
        {%- for item in search.results -%}
          <a href="{{ item.url }}" class="product-card" data-reveal>
            <div class="product-card__media">
              {%- if item.featured_media -%}
                {{ item.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', alt: item.title }}
              {%- elsif item.image -%}
                {{ item.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: item.title }}
              {%- endif -%}
            </div>
            <div class="product-card__title">{{ item.title }}</div>
          </a>
        {%- else -%}
          <p class="lead">{{ 'collections.general.empty' | t }}</p>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search" }
{% endschema %}
