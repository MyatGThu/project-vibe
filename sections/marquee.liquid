{%- liquid
  assign items = section.settings.text | split: ','
-%}
<div class="marquee section--tight" aria-hidden="true">
  <div class="marquee__track">
    {%- for i in (1..2) -%}
      {%- for item in items -%}<span class="marquee__item">{{ item | strip }}</span>{%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "text", "id": "text", "label": "Phrases (comma-separated)", "default": "Made to order, Zero waste, Digital atelier, Modelled using an AI model, Shipped worldwide" }
  ],
  "presets": [{ "name": "Marquee" }]
}
{% endschema %}
