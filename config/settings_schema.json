[
  {
    "name": "theme_info",
    "theme_name": "Melina — POD Editorial",
    "theme_version": "0.1.0",
    "theme_author": "Project — Shopify",
    "theme_documentation_url": "https://github.com/MyatGThu/Project---Shopify",
    "theme_support_url": "https://github.com/MyatGThu/Project---Shopify/issues"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Direction A · Editorial Luxe (default). See docs/DESIGN_SYSTEM.md for alternatives."
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "playfair_display_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "inter_n4"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg", "label": "Background (bone)", "default": "#f6f3ee" },
      { "type": "color", "id": "color_surface", "label": "Surface / cards", "default": "#ffffff" },
      { "type": "color", "id": "color_ink", "label": "Text (ink)", "default": "#161413" },
      { "type": "color", "id": "color_muted", "label": "Muted text", "default": "#6e6a64" },
      { "type": "color", "id": "color_line", "label": "Hairline borders", "default": "#e5dfd6" },
      { "type": "color", "id": "color_accent", "label": "Accent (bronze)", "default": "#b08d57" },
      { "type": "color", "id": "color_ink_bg", "label": "Dark sections background", "default": "#161413" },
      { "type": "color", "id": "color_on_ink", "label": "Text on dark sections", "default": "#f6f3ee" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1100,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1400
      }
    ]
  },
  {
    "name": "Loading screen",
    "settings": [
      {
        "type": "checkbox",
        "id": "loading_enabled",
        "label": "Enable loading screen",
        "default": true
      },
      {
        "type": "text",
        "id": "loading_text",
        "label": "Loader mark",
        "info": "Shown on the loading screen. Defaults to the store name.",
        "default": "Melina"
      }
    ]
  },
  {
    "name": "Branding",
    "settings": [{ "type": "image_picker", "id": "favicon", "label": "Favicon" }]
  }
]
